  },
  "files": [
    "dist/index.js",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "wordpress",
    "ai",
    "claude",
    "elementor",
    "seo",
    "chatgpt",
    "site-pilot"
  ],
  "dependencies": {},
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/node": "^20.11.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.3.3"
  },
  "author": "DigID",
  "license": "MIT"
}
