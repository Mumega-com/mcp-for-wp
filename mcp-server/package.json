{
  "name": "site-pilot-ai",
  "version": "2.1.2",
  "description": "MCP Server for WordPress - Manage posts, pages, SEO, forms & Elementor from Claude Desktop, Cursor, Windsurf and any MCP client",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "site-pilot-ai": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --target=node --outfile=dist/index.js --format=esm",
    "build:tsc": "tsc",
    "start": "node dist/index.js",
    "dev": "bun run src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Digidinc/wp-ai-operator"
  },
  "homepage": "https://github.com/Digidinc/wp-ai-operator#readme",
