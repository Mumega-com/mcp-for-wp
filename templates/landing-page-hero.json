{
  "_comment": "Elementor Landing Page Hero Template - Replace {{variables}} before use",
  "elementor_data": [
    {
      "id": "hero-section",
      "elType": "section",
      "settings": {
        "layout": "full_width",
        "height": "min-height",
        "custom_height": {"unit": "vh", "size": 80},
        "background_background": "classic",
        "background_color": "#1a1a2e"
      },
      "elements": [
        {
          "id": "hero-column",
          "elType": "column",
          "settings": {
            "content_position": "center",
            "_column_size": 100
          },
          "elements": [
            {
              "id": "hero-headline",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "{{headline}}",
                "header_size": "h1",
                "align": "center",
                "title_color": "#ffffff",
                "typography_typography": "custom",
                "typography_font_size": {"unit": "px", "size": 56}
              }
            },
            {
              "id": "hero-subheadline",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "{{subheadline}}",
                "header_size": "h2",
                "align": "center",
                "title_color": "#cccccc",
                "typography_font_size": {"unit": "px", "size": 24}
              }
            },
            {
              "id": "hero-cta",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "{{cta_text}}",
                "link": {"url": "{{cta_url}}"},
                "align": "center",
                "button_type": "default",
                "background_color": "#e94560",
                "button_text_color": "#ffffff",
                "border_radius": {"unit": "px", "size": 30},
                "typography_font_size": {"unit": "px", "size": 18},
                "button_padding": {
                  "unit": "px",
                  "top": 15,
                  "right": 40,
                  "bottom": 15,
                  "left": 40
                }
              }
            }
          ]
        }
      ]
    },
    {
      "id": "features-section",
      "elType": "section",
      "settings": {
        "layout": "boxed",
        "padding": {"unit": "px", "top": 80, "bottom": 80}
      },
      "elements": [
        {
          "id": "feature-1",
          "elType": "column",
          "settings": {"_column_size": 33},
          "elements": [
            {
              "id": "feature-1-icon",
              "elType": "widget",
              "widgetType": "icon",
              "settings": {
                "selected_icon": {"value": "fas fa-mountain", "library": "fa-solid"},
                "align": "center",
                "primary_color": "#e94560"
              }
            },
            {
              "id": "feature-1-title",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "{{feature_1_title}}",
                "header_size": "h3",
                "align": "center"
              }
            },
            {
              "id": "feature-1-desc",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "{{feature_1_description}}",
                "align": "center"
              }
            }
          ]
        },
        {
          "id": "feature-2",
          "elType": "column",
          "settings": {"_column_size": 33},
          "elements": [
            {
              "id": "feature-2-icon",
              "elType": "widget",
              "widgetType": "icon",
              "settings": {
                "selected_icon": {"value": "fas fa-biking", "library": "fa-solid"},
                "align": "center",
                "primary_color": "#e94560"
              }
            },
            {
              "id": "feature-2-title",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "{{feature_2_title}}",
                "header_size": "h3",
                "align": "center"
              }
            },
            {
              "id": "feature-2-desc",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "{{feature_2_description}}",
                "align": "center"
              }
            }
          ]
        },
        {
          "id": "feature-3",
          "elType": "column",
          "settings": {"_column_size": 33},
          "elements": [
            {
              "id": "feature-3-icon",
              "elType": "widget",
              "widgetType": "icon",
              "settings": {
                "selected_icon": {"value": "fas fa-users", "library": "fa-solid"},
                "align": "center",
                "primary_color": "#e94560"
              }
            },
            {
              "id": "feature-3-title",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "{{feature_3_title}}",
                "header_size": "h3",
                "align": "center"
              }
            },
            {
              "id": "feature-3-desc",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "{{feature_3_description}}",
                "align": "center"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "cta-section",
      "elType": "section",
      "settings": {
        "layout": "full_width",
        "background_background": "classic",
        "background_color": "#16213e",
        "padding": {"unit": "px", "top": 60, "bottom": 60}
      },
      "elements": [
        {
          "id": "cta-column",
          "elType": "column",
          "settings": {"_column_size": 100},
          "elements": [
            {
              "id": "cta-headline",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "{{final_cta_headline}}",
                "header_size": "h2",
                "align": "center",
                "title_color": "#ffffff"
              }
            },
            {
              "id": "final-cta-button",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "{{final_cta_text}}",
                "link": {"url": "{{final_cta_url}}"},
                "align": "center",
                "background_color": "#e94560"
              }
            }
          ]
        }
      ]
    }
  ]
}
